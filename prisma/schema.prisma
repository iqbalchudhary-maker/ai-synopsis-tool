generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Synopsis {
  id              String   @id @default(uuid())
  title_id        String   // Unique identifier
  title_name      String
  cast            String?  @db.Text
  director        String?
  source_synopsis String   @db.Text
  
  // AI Generated Content
  short_synopsis  String   @db.VarChar(120)
  medium_synopsis String   @db.VarChar(200)
  long_synopsis   String   @db.VarChar(350)
  
  // Translation
  language_code              String?
  translated_short_synopsis  String? @db.Text
  translated_medium_synopsis String? @db.Text
  translated_long_synopsis   String? @db.Text
  
  // Audit Trail & Control (Section 6.7)
  created_by      String   @default("system_user")
  updated_by      String?
  version         Int      @default(1)
  
  // Timestamps
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([title_id])
}